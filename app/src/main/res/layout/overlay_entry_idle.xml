<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Bar (70dp) -->
    <FrameLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="top"
        android:background="@color/navy">

        <!-- Logo Area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ailogo"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
                android:text="Active"
                android:textColor="@color/brand_red"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
                android:text="Park"
                android:textColor="@color/white"
                android:textSize="24sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
            android:text="14:32"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="40dp"
            android:fontFamily="@font/space_grotesk_regular"
            android:text="Thursday, 27 Feb 2026"
            android:textColor="@color/white_70"
            android:textSize="11sp" />
    </FrameLayout>

    <!-- Accent Line (3dp) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="70dp"
        android:background="@color/accent_red" />

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
            android:letterSpacing="0.12"
            android:text="WELCOME"
            android:textColor="@color/accent_red"
            android:textSize="42sp" />

        <View
            android:layout_width="240dp"
            android:layout_height="2dp"
            android:layout_marginTop="-8dp"
            android:background="@color/navy" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
                android:text="Active"
                android:textColor="@color/accent_red"
                android:textSize="80sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
                android:text="Park"
                android:textColor="@color/navy"
                android:textSize="80sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:fontFamily="@font/space_grotesk_regular"
            android:letterSpacing="0.42"
            android:text="Smart parking management"
            android:textColor="@color/accent_red"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- QR Code Card (bottom-right) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="56dp"
        android:background="@drawable/bg_qr_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgQrCode"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:src="@drawable/qrcode"
            android:contentDescription="QR Code" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk_bold"
                android:tag="bold"
            android:text="Scan to Visit"
            android:textColor="@color/accent_red"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk_regular"
            android:text="INVESTMENTCAM.COM"
            android:textColor="@color/accent_red"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Bottom Bar (36dp) -->
    <FrameLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_gravity="bottom"
        android:background="@color/navy">

        <TextView
            android:id="@+id/tvFooterVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="11dp"
            android:fontFamily="@font/space_grotesk_regular"
            android:text="ActivePark Parking System v1.0"
            android:textColor="@color/white_70"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgWifi"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_wifi"
                android:tint="@color/white_70"
                android:contentDescription="Wifi" />

            <TextView
                android:id="@+id/tvNetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/space_grotesk_regular"
                android:text="Connected"
                android:textColor="@color/white_70"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
