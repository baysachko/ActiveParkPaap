<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#1B1B1B"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PAAP Monitor"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Test"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:minWidth="60dp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:minWidth="60dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:minWidth="60dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnAutoRestart"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Auto:ON"
            android:textColor="#FFFFFF"
            android:backgroundTint="#388E3C"
            android:minWidth="80dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="X"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF0000"
            android:minWidth="40dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Page Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#222222"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Page:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnPageIdle"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:text="Idle"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPageTransaction"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Transaction"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="120dp" />

        <Button
            android:id="@+id/btnPageExitIdle"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Exit Idle"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPageExitTxn"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Exit Txn"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPageComplete"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Complete"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnRole"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:text="ENTRY"
            android:textColor="#FFFFFF"
            android:backgroundTint="#010062"
            android:minWidth="80dp" />
    </LinearLayout>

    <!-- Cash member demos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cash:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnCashEntry"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:text="Entry"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnCashEntryDeny"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Entry Deny"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="100dp" />

        <Button
            android:id="@+id/btnCashExit"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Exit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnCashExitDeny"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Exit Deny"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="100dp" />

        <Button
            android:id="@+id/btnExpiredEntry"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:text="Exp Entry"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="100dp" />

        <Button
            android:id="@+id/btnExpiredExit"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Exp Exit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444"
            android:minWidth="100dp" />
    </LinearLayout>

    <!-- Payment state demos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pay:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnPageExpired"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:text="Expired"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF5555"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPageError"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Error"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF5555"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPageGateFail"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Gate Fail"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E8A000"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPagePaid"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Paid"
            android:textColor="#FFFFFF"
            android:backgroundTint="#22C55E"
            android:minWidth="80dp" />

        <Button
            android:id="@+id/btnPagePaidComplete"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Paid Exit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#22C55E"
            android:minWidth="80dp" />
    </LinearLayout>

    <!-- Ticket Printer Test -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A2E1A"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Printer:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etPrintCardNo"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="#333333"
            android:hint="Card No"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="14sp"
            android:inputType="text"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnPrintTest"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Print"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E91E63"
            android:minWidth="60dp" />

        <Button
            android:id="@+id/btnPrintToggle"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="ON"
            android:textColor="#FFFFFF"
            android:backgroundTint="#388E3C"
            android:minWidth="50dp" />

        <TextView
            android:id="@+id/tvPrintStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ADB Remote Access -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server IP:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etServerIp"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="#333333"
            android:hint="192.168.x.x"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="14sp"
            android:inputType="text"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnSaveIp"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#388E3C"
            android:minWidth="60dp" />

        <TextView
            android:id="@+id/tvAdbStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="ADB:OFF"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online Payment:"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnPaymentToggle"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="OFF"
            android:textColor="#FFFFFF"
            android:backgroundTint="#666666"
            android:minWidth="50dp" />

        <EditText
            android:id="@+id/etApiUrl"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="#333333"
            android:hint="API URL"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:inputType="textUri"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="#333333"
            android:hint="API Key"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:inputType="text"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <EditText
            android:id="@+id/etPollInterval"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="#333333"
            android:hint="10000"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:inputType="number"
            android:singleLine="true"
            android:minWidth="80dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnSavePayment"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="4dp"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#388E3C"
            android:minWidth="60dp" />

        <TextView
            android:id="@+id/tvPaymentConfigStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="PAY:OFF"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPaapWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D32F2F"
        android:gravity="center"
        android:padding="8dp"
        android:text="PAAP NOT IN FOREGROUND"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Waiting for PAAP events...\n\nOn ticket box: events appear automatically.\nOn emulator: tap Test to inject fake events."
        android:textColor="#888888"
        android:textSize="14sp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEvents"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>
