<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Left panel: ticket info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="65"
        android:orientation="vertical"
        android:paddingStart="54dp"
        android:paddingTop="27dp">

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tag="bold"
            android:letterSpacing="0.15"
            android:text="EXITING"
            android:textColor="#E8A000"
            android:textSize="24sp" />

        <View
            android:id="@+id/tvStatusLine"
            android:layout_width="120dp"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:background="#E8A000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="TICKET NO."
            android:textColor="#888888"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvPlate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:tag="bold"
            android:maxLines="1"
            android:letterSpacing="-0.02"
            android:text="CB12345"
            android:textColor="@color/navy"
            android:textSize="120sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="PARKING TIME"
            android:textColor="#888888"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvParkingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:tag="bold"
            android:text="02:35:12"
            android:textColor="#333333"
            android:textSize="56sp" />

        <TextView
            android:id="@+id/tvPayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="PLEASE PAY"
            android:textColor="#888888"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvPayAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:tag="bold"
            android:letterSpacing="-0.02"
            android:text="$4.00"
            android:textColor="@color/accent_red"
            android:textSize="80sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#E0E0E0" />

    <!-- Right panel: QR + status + timer -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="35"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivQrPayment"
            android:layout_width="216dp"
            android:layout_height="448dp"
            android:scaleType="fitCenter"
            android:contentDescription="Payment QR" />

        <ImageView
            android:id="@+id/ivCheckmark"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/checkmark_area"
            android:visibility="gone"
            android:contentDescription="Payment confirmed" />

        <ImageView
            android:id="@+id/ivErrorIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/error_area"
            android:visibility="gone"
            android:contentDescription="Payment error" />

        <ImageView
            android:id="@+id/ivExpiredIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/expired_area"
            android:visibility="gone"
            android:contentDescription="Payment expired" />

        <ImageView
            android:id="@+id/ivWarningIcon"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/warning_area"
            android:visibility="gone"
            android:contentDescription="Gate warning" />

        <TextView
            android:id="@+id/tvPaymentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:tag="bold"
            android:gravity="center"
            android:textColor="#E8A000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvPaymentTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvHelpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:gravity="center"
            android:visibility="gone"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
