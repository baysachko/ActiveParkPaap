<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="54dp"
    android:paddingTop="27dp">

    <!-- Status Label -->
    <TextView
        android:id="@+id/tvStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:tag="bold"
        android:letterSpacing="0.15"
        android:text="EXITING"
        android:textColor="#E8A000"
        android:textSize="24sp" />

    <!-- Status Underline -->
    <View
        android:id="@+id/tvStatusLine"
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:layout_marginTop="4dp"
        android:background="#E8A000" />

    <!-- Ticket No label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="TICKET NO."
        android:textColor="#888888"
        android:textSize="24sp" />

    <!-- Plate Number -->
    <TextView
        android:id="@+id/tvPlate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-8dp"
        android:tag="bold"
        android:maxLines="1"
        android:letterSpacing="-0.02"
        android:text="CB12345"
        android:textColor="@color/navy"
        android:textSize="120sp" />

    <!-- Parking Time label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="PARKING TIME"
        android:textColor="#888888"
        android:textSize="22sp" />

    <!-- Parking Time -->
    <TextView
        android:id="@+id/tvParkingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:tag="bold"
        android:text="02:35:12"
        android:textColor="#333333"
        android:textSize="56sp" />

    <!-- Please Pay label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="PLEASE PAY"
        android:textColor="#888888"
        android:textSize="22sp" />

    <!-- Pay Amount -->
    <TextView
        android:id="@+id/tvPayAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:tag="bold"
        android:letterSpacing="-0.02"
        android:text="$4.00"
        android:textColor="@color/accent_red"
        android:textSize="80sp" />
</LinearLayout>
