<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Bar (70dp) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="top"
        android:background="@color/navy">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ailogo"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:tag="bold"
                android:text="Active"
                android:textColor="@color/brand_red"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tag="bold"
                android:text="Park"
                android:textColor="@color/white"
                android:textSize="24sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            android:tag="bold"
            android:text="14:32"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="40dp"
            android:text="Thursday, 27 Feb 2026"
            android:textColor="@color/white_70"
            android:textSize="11sp" />
    </FrameLayout>

    <!-- Accent Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="70dp"
        android:background="@color/accent_red" />

    <!-- Content Area -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="54dp"
        android:layout_marginTop="100dp"
        android:orientation="vertical">

        <!-- Status Label -->
        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tag="bold"
            android:letterSpacing="0.15"
            android:text="EXITING"
            android:textColor="#E8A000"
            android:textSize="24sp" />

        <!-- Status Underline -->
        <View
            android:id="@+id/tvStatusLine"
            android:layout_width="120dp"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:background="#E8A000" />

        <!-- Ticket No label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="TICKET NO."
            android:textColor="#888888"
            android:textSize="24sp" />

        <!-- Plate Number -->
        <TextView
            android:id="@+id/tvPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:tag="bold"
            android:letterSpacing="-0.02"
            android:text="CB12345"
            android:textColor="@color/navy"
            android:textSize="120sp" />

        <!-- Parking Time label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="PARKING TIME"
            android:textColor="#888888"
            android:textSize="22sp" />

        <!-- Parking Time -->
        <TextView
            android:id="@+id/tvParkingTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:tag="bold"
            android:text="02:35:12"
            android:textColor="#333333"
            android:textSize="56sp" />

        <!-- Please Pay label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:tag="bold"
            android:letterSpacing="0.12"
            android:text="PLEASE PAY"
            android:textColor="#888888"
            android:textSize="22sp" />

        <!-- Pay Amount -->
        <TextView
            android:id="@+id/tvPayAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:tag="bold"
            android:letterSpacing="-0.02"
            android:text="$4.00"
            android:textColor="@color/accent_red"
            android:textSize="80sp" />
    </LinearLayout>

    <!-- QR Code Card (bottom-right) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="56dp"
        android:background="@drawable/bg_qr_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:src="@drawable/qrcode"
            android:contentDescription="QR Code" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tag="bold"
            android:text="Scan to Visit"
            android:textColor="@color/accent_red"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INVESTMENTCAM.COM"
            android:textColor="@color/accent_red"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Bottom Bar (36dp) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_gravity="bottom"
        android:background="@color/navy">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="11dp"
            android:text="ActivePark Parking System v1.0"
            android:textColor="@color/white_70"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_wifi"
                android:tint="@color/white_70"
                android:contentDescription="Wifi" />

            <TextView
                android:id="@+id/tvNetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Connected"
                android:textColor="@color/white_70"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
