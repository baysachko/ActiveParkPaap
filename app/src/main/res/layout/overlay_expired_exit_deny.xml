<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="54dp"
    android:paddingTop="27dp">

    <!-- Status Label -->
    <TextView
        android:id="@+id/tvStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:tag="bold"
        android:letterSpacing="0.15"
        android:text="Exit Deny"
        android:textColor="#ff5555"
        android:textSize="24sp" />

    <!-- Status Underline -->
    <View
        android:id="@+id/tvStatusLine"
        android:layout_width="144dp"
        android:layout_height="2dp"
        android:layout_marginTop="4dp"
        android:background="#ff5555" />

    <!-- Ticket No label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="TICKET NO."
        android:textColor="#888888"
        android:textSize="24sp" />

    <!-- Plate/Ticket Number -->
    <TextView
        android:id="@+id/tvPlate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-8dp"
        android:tag="bold"
        android:maxLines="1"
        android:letterSpacing="-0.02"
        android:text="CB12345"
        android:textColor="@color/navy"
        android:textSize="120sp" />

    <!-- Type Badge -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_type_badge"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:tag="bold"
            android:letterSpacing="0.08"
            android:text="Vehicle is Expired"
            android:textColor="@color/white"
            android:textSize="32sp" />
    </FrameLayout>

    <!-- Valid Date label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="Valid Date"
        android:textColor="#888888"
        android:textSize="22sp" />

    <!-- Valid Date -->
    <TextView
        android:id="@+id/tvValidDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:tag="bold"
        android:letterSpacing="-0.01"
        android:text="04/23/2025"
        android:textColor="#333333"
        android:textSize="56sp" />
</LinearLayout>
