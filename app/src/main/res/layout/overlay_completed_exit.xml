<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="54dp"
    android:paddingTop="27dp">

    <!-- Status Label -->
    <TextView
        android:id="@+id/tvStatusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:tag="bold"
        android:letterSpacing="0.15"
        android:text="EXITED"
        android:textColor="#22C55E"
        android:textSize="24sp" />

    <!-- Status Underline -->
    <View
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:layout_marginTop="4dp"
        android:background="#22C55E" />

    <!-- Ticket No label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="TICKET NO."
        android:textColor="#888888"
        android:textSize="24sp" />

    <!-- Plate Number -->
    <TextView
        android:id="@+id/tvPlate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-8dp"
        android:tag="bold"
        android:maxLines="1"
        android:letterSpacing="-0.02"
        android:text="CB12345"
        android:textColor="@color/navy"
        android:textSize="120sp" />

    <!-- Type Badge -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_type_badge">

        <TextView
            android:id="@+id/tvTypeBadge"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:tag="bold"
            android:letterSpacing="0.08"
            android:text="TEMPORARY"
            android:textColor="@color/white"
            android:textSize="32sp" />
    </FrameLayout>

    <!-- Exit Date label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="EXIT DATE"
        android:textColor="#888888"
        android:textSize="22sp" />

    <!-- Exit Date -->
    <TextView
        android:id="@+id/tvExitDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:tag="bold"
        android:letterSpacing="-0.01"
        android:text="02/27/26 14:32:05"
        android:textColor="#333333"
        android:textSize="56sp" />

    <!-- Thank You -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:tag="bold"
        android:letterSpacing="0.12"
        android:text="THANK YOU"
        android:textColor="#22C55E"
        android:textSize="36sp" />
</LinearLayout>
